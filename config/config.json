{
  "arxiv": {
    "categories": ["cs.CV", "cs.RO"],
    "max_results": 200,
    "recent_days": 3,
    "adaptive_recent_days": true,
    "citation_lookback_days": 60,
    "min_citations_for_highlight": 5
  },
  "report": {
    "max_papers": 10,
    "languages": ["en"],
    "output_format": ["markdown", "html"],
    "output_directory": "reports"
  },
  "email": {
    "enabled": true,
    "subject_prefix": "[Arxiv CV Report]",
    "include_full_report": true,
    "include_summary": true
  },
  "llm": {
    "provider": "gemini",
    "model": "gemini-3.1-flash-lite",
    "temperature": 1.0,
    "max_output_tokens": 8192,
    "summary_length": "medium",
    "batch_size": 16,
    "pdf_provider": "gemini",
    "pdf_model": "gemini-3.1-flash-lite",
    "scoring_provider": "openai",
    "scoring_model": "deepseek-chat",
    "scoring_base_url": "https://api.deepseek.com"
  },
  "ranking": {
    "min_combined_score": 4,
    "relevance_weight": 0.6,
    "significance_weight": 0.4,
    "pre_filter_factor": 3
  }
}
